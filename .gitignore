# =============================================================================
# Homelab GitOps Infrastructure — Git Ignore
# =============================================================================
# This file ensures sensitive data and local configuration are never committed.
# All environment-specific values live in .env files (see infra/env.example).

# -----------------------------------------------------------------------------
# Environment & Secrets — NEVER commit these
# -----------------------------------------------------------------------------
**/.env
**/.env.*
!**/.env.example
infra/.env
*.secret
*.secret.yaml
*.secret.yml
*secret*.yaml
*secret*.yml
!**/secrets/README.md
!**/secrets/*.example

# Kubernetes secrets
**/sealed-secrets/*.yaml
!**/secrets/.gitkeep

# Cilium values — contains real cluster config, use values.example.yaml as template
infra/cilium/values.yaml
!infra/cilium/values.example.yaml

# TLS certificates and keys
*.key
*.crt
*.pem
*.p12
*.pfx
*.jks

# Kubeconfig files
kubeconfig
*.kubeconfig
config-homelab

# -----------------------------------------------------------------------------
# K3s / Cluster state
# -----------------------------------------------------------------------------
k3s.yaml
*.kubeconfig

# -----------------------------------------------------------------------------
# Ansible
# -----------------------------------------------------------------------------
ansible/inventory.yml
ansible/inventory.yaml
ansible/*.log
ansible/roles/*/tests/

# -----------------------------------------------------------------------------
# IDE & Editor files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------------
# Tool output & caches
# -----------------------------------------------------------------------------
.helm/
*.tgz
.trivy-cache/
.gocache/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
Thumbs.db

# =============================================================================
# Proxmox + OpenTofu
# =============================================================================

# Environment
proxmox/.env

# OpenTofu state & provider cache
proxmox/opentofu/**/.terraform/
proxmox/opentofu/**/*.tfstate
proxmox/opentofu/**/*.tfstate.*
proxmox/opentofu/**/*.backup
proxmox/opentofu/**/crash.log
proxmox/opentofu/**/override.tf
proxmox/opentofu/**/override.tf.json
proxmox/opentofu/**/*_override.tf
proxmox/opentofu/**/*_override.tf.json
proxmox/opentofu/**/.terraform.tfstate.lock.info

# OpenTofu plan files (binary, not diffs)
proxmox/opentofu/**/*.tfplan

# OpenTofu variables (copy from .example)
proxmox/opentofu/terraform.tfvars
!proxmox/opentofu/terraform.tfvars.example
proxmox/ansible/inventory.yml
proxmox/ansible/inventory.ini
proxmox/ansible/**/*.retry

# SSH keys (never commit)
proxmox/**/*.pem
proxmox/**/*.key
proxmox/**/id_*
proxmox/**/*_rsa
proxmox/**/*_ed25519

# Cloud-init rendered files
proxmox/cloud-init/*.rendered.yaml


