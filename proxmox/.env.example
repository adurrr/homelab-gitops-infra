# =============================================================================
# Proxmox + OpenTofu Infrastructure — Environment Configuration
# =============================================================================
# Copy this file to proxmox/.env and fill in your real values.
# proxmox/.env is gitignored — never commit real credentials, tokens, or keys.
#
# Used by: Ansible playbooks (Phase 3-4), network configuration, K3s setup
# NOT used by: OpenTofu (uses terraform.tfvars directly)
#
# Usage:
#   1. cp proxmox/.env.example proxmox/.env
#   2. vim proxmox/.env
#   3. source proxmox/.env
# =============================================================================

# ---------------------------------------------------------------------------
# SSH — for connecting to VMs
# ---------------------------------------------------------------------------
SSH_USER=ubuntu                      # Cloud-init default user on VMs
SSH_KEY_PATH=~/.ssh/proxmox_vm_key   # Private key matching Proxmox sshkey

# ---------------------------------------------------------------------------
# K3s Cluster Tokens (used by Ansible Phase 4)
# ---------------------------------------------------------------------------
K3S_TOKEN_TESTING=testing-token-change-me
K3S_TOKEN_STAGING=staging-token-change-me
# Production token — MUST match existing cluster token
# Retrieve from existing K3s server: cat /var/lib/rancher/k3s/server/token
K3S_TOKEN_PROD=prod-token-change-me

# ---------------------------------------------------------------------------
# Existing Production Cluster
# ---------------------------------------------------------------------------
EXISTING_K3S_SERVER_IP=192.168.50.60
EXISTING_K3S_SERVER_PORT=6443

# ---------------------------------------------------------------------------
# Network
# ---------------------------------------------------------------------------
# Production VM (untagged, same subnet as existing cluster)
PROD_VM_IP=192.168.50.65
PROD_VM_GATEWAY=192.168.50.1

# Staging VM (VLAN 20)
STAGING_VM_IP=10.0.20.11
STAGING_VM_GATEWAY=10.0.20.1

# Testing VM (VLAN 30)
TESTING_VM_IP=10.0.30.11
TESTING_VM_GATEWAY=10.0.30.1

# ---------------------------------------------------------------------------
# Proxmox (for Ansible proxying)
# ---------------------------------------------------------------------------
PROXMOX_HOST=192.168.50.202
PROXMOX_SSH_PORT=4749

# ---------------------------------------------------------------------------
# K8sGPT (AIOps v1 — cloud LLM backend)
# ---------------------------------------------------------------------------
# Set this before Phase 6. Store via K8s Secret/SealedSecret, not here.
# OPENAI_API_KEY=sk-xxxx

# ---------------------------------------------------------------------------
# Timezone
# ---------------------------------------------------------------------------
TIMEZONE=America/New_York
