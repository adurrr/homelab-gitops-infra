# =============================================================================
# Homelab GitOps Infrastructure — Environment Configuration
# =============================================================================
# Copy this file to infra/.env and fill in your real values.
# infra/.env is gitignored — your real IPs and names will never be committed.
# =============================================================================

# Network
CONTROL_PLANE_IP=192.168.1.10    # Your K3s server IP
WORKER_IP=192.168.1.20           # Your K3s agent IP
METALLB_IP_RANGE=192.168.1.230-192.168.1.240
LAN_SUBNET=192.168.1.0/24
GATEWAY_IP=192.168.1.1

# K3s
K3S_TOKEN=changeme                # From /var/lib/rancher/k3s/server/token on server
K3S_POD_CIDR=10.42.0.0/16

# Node hostnames used in docs and runbooks
SERVER_HOSTNAME=server            # Control plane node name
WORKER_HOSTNAME=worker            # Worker node name

# GitHub — for ArgoCD repo references
GITHUB_USER=your-github           # Your GitHub username
REPO_NAME=homelab-gitops-infra    # Keep or rename

# Home Assistant
HA_CONFIG_PATH=~/ha-config        # Local path to your HA configuration.yaml

# Timezone (for Home Assistant, all services)
TIMEZONE=Europe/Madrid

# TLS — internal domains (resolved via /etc/hosts or local DNS)
DOMAIN_SUFFIX=homelab.local

# =============================================================================
# Usage:
#   1. cp infra/env.example infra/.env
#   2. vim infra/.env
#   3. source infra/.env
#   4. Run setup scripts or manually replace placeholders in GitOps files
# =============================================================================
