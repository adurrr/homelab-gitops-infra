# =============================================================================
# Alertmanager → Telegram Bridge — SealedSecret Template
# =============================================================================
# DO NOT commit this file as-is. It contains placeholder values.
#
# To create the real sealed secret:
#   1. Copy this template to  alertmanager-telegram-secret.yaml (gitignored)
#   2. Replace placeholder values with your real bot token and chat ID
#   3. Seal it with kubeseal:
#        kubeseal --format yaml < alertmanager-telegram-secret.yaml \
#          > security/secrets/alertmanager-telegram-sealed.yaml
#   4. Commit ONLY security/secrets/alertmanager-telegram-sealed.yaml
#   5. Delete the unsealed alertmanager-telegram-secret.yaml
#
# How to get the values:
#   Bot token:  Message @BotFather on Telegram → /newbot → copy HTTP API token
#   Chat ID:    Message @userinfobot on Telegram → copy the "Id" field
#               Or: start a chat with your bot, then GET
#               https://api.telegram.org/bot<TOKEN>/getUpdates
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: alertmanager-telegram-secret
  namespace: monitoring
type: Opaque
stringData:
  TELEGRAM_BOT_TOKEN: "REPLACE_WITH_YOUR_BOT_TOKEN"
  TELEGRAM_CHAT_ID: "REPLACE_WITH_YOUR_CHAT_ID"
